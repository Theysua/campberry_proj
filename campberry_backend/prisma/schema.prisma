generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  password_hash  String?
  name           String
  avatar_url     String?
  role           String             @default("STUDENT")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  is_verified    Boolean            @default(false)
  email_verification_tokens EmailVerificationToken[]
  password_reset_tokens PasswordResetToken[]
  lists          List[]
  list_reviews   ListReview[]
  saved_lists    UserSavedList[]
  program_reviews ProgramReview[]
  saved_programs UserSavedProgram[]
  refresh_tokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("password_reset_tokens")
}

model VerificationToken {
  id         String   @id @default(uuid())
  email      String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@index([expires_at])
  @@map("verification_tokens")
}

model Program {
  id                    String             @id @default(uuid())
  name                  String
  provider_id           String
  description           String?
  type                  String             @default("PROGRAM")
  url                   String?
  logo_url              String?
  is_highly_selective   Boolean?           @default(false)
  cost_info             String?
  admission_info        String?
  eligibility_info      String?
  experts_choice_rating String?
  impact_rating         String?
  eligible_grades       String?
  only_us_citizens      Boolean?           @default(false)
  only_us_residents     Boolean?           @default(false)
  allows_international  Boolean?           @default(true)
  offers_college_credit Boolean?           @default(false)
  is_one_on_one         Boolean?           @default(false)
  trpc_data             String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  deadlines             Deadline[]
  list_items            ListItem[]
  reviews               ProgramReview[]
  interests             ProgramInterest[]
  provider              Provider           @relation(fields: [provider_id], references: [id])
  sessions              Session[]
  saved_by              UserSavedProgram[]

  @@index([provider_id])
  @@index([type])
  @@index([experts_choice_rating])
  @@index([impact_rating])
  @@index([is_highly_selective])
  @@index([allows_international])
  @@index([offers_college_credit])
  @@index([is_one_on_one])
  @@index([created_at])
  @@map("programs")
}

model Provider {
  id       String    @id @default(uuid())
  name     String    @unique
  programs Program[]

  @@map("providers")
}

model Interest {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  programs ProgramInterest[]

  @@map("interests")
}

model ProgramInterest {
  program_id  String
  interest_id Int
  interest    Interest @relation(fields: [interest_id], references: [id])
  program     Program  @relation(fields: [program_id], references: [id])

  @@id([program_id, interest_id])
  @@index([interest_id, program_id])
  @@map("program_interests")
}

model Session {
  id            String    @id @default(uuid())
  program_id    String
  start_date    DateTime?
  end_date      DateTime?
  location_type String?
  location_name String?
  location_lat  Float?
  location_lng  Float?
  program       Program   @relation(fields: [program_id], references: [id])

  @@index([program_id])
  @@index([location_type, program_id])
  @@index([location_name])
  @@index([location_lat, location_lng])
  @@index([start_date, end_date])
  @@map("sessions")
}

model Deadline {
  id          String   @id @default(uuid())
  program_id  String
  description String
  date        DateTime
  program     Program  @relation(fields: [program_id], references: [id])

  @@index([program_id, date])
  @@map("deadlines")
}

model List {
  id          String     @id @default(uuid())
  title       String
  description String?
  author_id   String
  is_public   Boolean?   @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  items       ListItem[]
  reviews     ListReview[]
  saved_by    UserSavedList[]
  author      User       @relation(fields: [author_id], references: [id])

  @@index([author_id, updated_at])
  @@index([is_public, updated_at])
  @@map("lists")
}

model ListItem {
  id                String   @id @default(uuid())
  list_id           String
  program_id        String?
  author_commentary String?
  display_order     Int
  type              String   @default("PROGRAM")
  list              List     @relation(fields: [list_id], references: [id])
  program           Program? @relation(fields: [program_id], references: [id])

  @@index([list_id, display_order])
  @@index([program_id])
  @@map("list_items")
}

model UserSavedProgram {
  user_id    String
  program_id String
  saved_at   DateTime @default(now())
  program    Program  @relation(fields: [program_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@id([user_id, program_id])
  @@index([program_id])
  @@map("user_saved_programs")
}

model UserSavedList {
  user_id   String
  list_id   String
  saved_at  DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id])
  list      List     @relation(fields: [list_id], references: [id])

  @@id([user_id, list_id])
  @@index([list_id])
  @@map("user_saved_lists")
}

model ProgramReview {
  id         String   @id @default(uuid())
  program_id String
  user_id    String
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  program    Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([program_id, user_id])
  @@index([program_id, created_at])
  @@index([user_id, created_at])
  @@map("program_reviews")
}

model ListReview {
  id         String   @id @default(uuid())
  list_id    String
  user_id    String
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  list       List     @relation(fields: [list_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([list_id, user_id])
  @@index([list_id, created_at])
  @@index([user_id, created_at])
  @@map("list_reviews")
}
