generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  password_hash  String?
  name           String
  avatar_url     String?
  role           String             @default("STUDENT")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  is_verified    Boolean            @default(false)
  lists          List[]
  saved_programs UserSavedProgram[]
  refresh_tokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Program {
  id                    String             @id @default(uuid())
  name                  String
  provider_id           String
  description           String?
  type                  String             @default("PROGRAM")
  url                   String?
  logo_url              String?
  is_highly_selective   Boolean?           @default(false)
  cost_info             String?
  admission_info        String?
  eligibility_info      String?
  experts_choice_rating String?
  impact_rating         String?
  // Note: SQLite doesn't directly support String[]. If this becomes an issue we might need a relation, but Prisma handles it via JSON.
  // Wait, Prisma SQLite does not support scalar lists (like Int[]). We will change eligible_grades to a String (comma separated) for MVP.
  eligible_grades       String?
  only_us_citizens      Boolean?           @default(false)
  only_us_residents     Boolean?           @default(false)
  allows_international  Boolean?           @default(true)
  offers_college_credit Boolean?           @default(false)
  is_one_on_one         Boolean?           @default(false)
  // SQLite does not support Json. We map trpc_data to String.
  trpc_data             String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  deadlines             Deadline[]
  list_items            ListItem[]
  interests             ProgramInterest[]
  provider              Provider           @relation(fields: [provider_id], references: [id])
  sessions              Session[]
  saved_by              UserSavedProgram[]

  @@map("programs")
}

model Provider {
  id       String    @id @default(uuid())
  name     String    @unique
  programs Program[]

  @@map("providers")
}

model Interest {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  programs ProgramInterest[]

  @@map("interests")
}

model ProgramInterest {
  program_id  String
  interest_id Int
  interest    Interest @relation(fields: [interest_id], references: [id])
  program     Program  @relation(fields: [program_id], references: [id])

  @@id([program_id, interest_id])
  @@map("program_interests")
}

model Session {
  id            String    @id @default(uuid())
  program_id    String
  start_date    DateTime?
  end_date      DateTime?
  location_type String?
  location_name String?
  location_lat  Float?
  location_lng  Float?
  program       Program   @relation(fields: [program_id], references: [id])

  @@map("sessions")
}

model Deadline {
  id          String   @id @default(uuid())
  program_id  String
  description String
  date        DateTime
  program     Program  @relation(fields: [program_id], references: [id])

  @@map("deadlines")
}

model List {
  id          String     @id @default(uuid())
  title       String
  description String?
  author_id   String
  is_public   Boolean?   @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  items       ListItem[]
  author      User       @relation(fields: [author_id], references: [id])

  @@map("lists")
}

model ListItem {
  id                String   @id @default(uuid())
  list_id           String
  program_id        String?
  author_commentary String?
  display_order     Int
  type              String   @default("PROGRAM")
  list              List     @relation(fields: [list_id], references: [id])
  program           Program? @relation(fields: [program_id], references: [id])

  @@map("list_items")
}

model UserSavedProgram {
  user_id    String
  program_id String
  saved_at   DateTime @default(now())
  program    Program  @relation(fields: [program_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@id([user_id, program_id])
  @@map("user_saved_programs")
}
